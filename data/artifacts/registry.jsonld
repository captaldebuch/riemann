      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB4.riemannZeta_ne_zero_of_nymanBeurlingCriterion",
      "statement": "theorem riemannZeta_ne_zero_of_nymanBeurlingCriterion (hcriterion : NymanBeurlingCriterion) {s : ℂ} (hs0 : 1 / 2 < s.re) (hs1 : s.re < 1) : riemannZeta s ≠ 0",
