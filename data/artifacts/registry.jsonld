      "@id": "theorem:NBMellinTools.NB2.mellin_fract_eq_head_add_fractTail",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB2.mellin_fract_eq_head_add_fractTail",
      "statement": "theorem mellin_fract_eq_head_add_fractTail {s : ℂ} (h0 : 0 < s.re) (h1 : s.re < 1) : mellin (fun x : ℝ ↦ ((Int.fract x : ℝ) : ℂ)) (-s) = 1 / (1 - s) + fractTail s 1",
