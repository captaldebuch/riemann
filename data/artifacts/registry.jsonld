    {
      "@id": "theorem:NBMellinTools.NB2.mellin_rhoBD_of_base",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB2.mellin_rhoBD_of_base",
      "statement": "theorem mellin_rhoBD_of_base (k : ℕ) (s : ℂ) (hbase : mellin (fun x : ℝ ↦ (rhoBase x : ℂ)) s = -(riemannZeta s) / s) : mellin (fun x : ℝ ↦ (rhoBD k x : ℂ)) s = -(riemannZeta s) / (s * ((((k + 1 : ℕ) : ℝ) : ℂ) ^ s))",
      "source": {
        "file": "proofs/NBMellinTools/NB2Mellin.lean",
