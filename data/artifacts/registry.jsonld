      "@id": "theorem:NBMellinTools.NB3.mellin_error_part_A_bound",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB3.mellin_error_part_A_bound",
      "statement": "theorem mellin_error_part_A_bound {s : ℂ} (hs : 1 / 2 < s.re) (N : ℕ) (coeffs : Fin N → ℝ) : ‖∫ x in Ioc (0 : ℝ) 1, mellinKernel s x * mellinError N coeffs x‖ ≤ (1 / Real.sqrt (2 * s.re - 1)) * Real.sqrt (BaezDuarteL2Error N coeffs)",
