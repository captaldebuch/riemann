      "@id": "theorem:NBMellinTools.NB2.mellin_fract_inv_eq_neg_zeta_div",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB2.mellin_fract_inv_eq_neg_zeta_div",
      "statement": "theorem mellin_fract_inv_eq_neg_zeta_div {s : ℂ} (h0 : 0 < s.re) (h1 : s.re < 1) : mellin (fun x : ℝ ↦ ((Int.fract x : ℝ) : ℂ)) (-s) = -riemannZeta s / s",
