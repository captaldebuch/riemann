      "name": "NBMellinTools.NB2.zeta_eq_zetaTailRHS_on_convex",
      "statement": "theorem zeta_eq_zetaTailRHS_on_convex {U : Set ℂ} (hUopen : IsOpen U) (hUconv : Convex ℝ U) (hUre : ∀ z ∈ U, 0 < z.re) (hUone : (1 : ℂ) ∉ U) {z₀ : ℂ} (hz₀U : z₀ ∈ U) (hz₀re : 1 < z₀.re) : Set.EqOn riemannZeta zetaTailRHS U",
