    {
      "@id": "theorem:NBMellinTools.norm_setIntegral_mul_le_sqrt_mul_sqrt",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.norm_setIntegral_mul_le_sqrt_mul_sqrt",
      "statement": "theorem norm_setIntegral_mul_le_sqrt_mul_sqrt (f g : α → ℂ) [MeasurableSpace α] (s : Set α) (μ : Measure α) (hf : MemLp f 2 (μ.restrict s)) (hg : MemLp g 2 (μ.restrict s)) : ‖∫ x in s, f x * g x ∂μ‖ ≤ Real.sqrt (∫ x in s, ‖f x‖ ^ 2 ∂μ) * Real.sqrt (∫ x in s, ‖g x‖ ^ 2 ∂μ)",
      "source": {
        "file": "proofs/NBMellinTools/MellinEvaluation.lean",
        "line": 23,
        "module": "NBMellinTools.MellinEvaluation",
