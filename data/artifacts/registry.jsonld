      ],
      "summary": "- The unconditional Mellin formula for the zero-based Báez--Duarte generators."
    },
    {
      "@id": "theorem:NBMellinTools.NB2.mellin_rhoBD_eq_scaled_base",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB2.mellin_rhoBD_eq_scaled_base",
      "statement": "theorem mellin_rhoBD_eq_scaled_base (k : ℕ) (s : ℂ) : mellin (fun x : ℝ ↦ (rhoBD k x : ℂ)) s = (((((k + 1 : ℕ) : ℝ) : ℂ) ^ (-s))) • mellin (fun x : ℝ ↦ (rhoBase x : ℂ)) s",
      "source": {
