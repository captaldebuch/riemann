      "@id": "theorem:NBMellinTools.NB3.mellin_error_tail_part_B_bound",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB3.mellin_error_tail_part_B_bound",
      "statement": "theorem mellin_error_tail_part_B_bound {s : ℂ} (hs : s.re < 1) (N : ℕ) (coeffs : Fin N → ℝ) : ‖∫ x in Ioi (1 : ℝ), mellinKernel s x * mellinError N coeffs x‖ ≤ (1 / (1 - s.re)) * Real.sqrt (BaezDuarteL2Error N coeffs)",
