      "@id": "theorem:NBMellinTools.NB2.fractTail_one_eq_of_one_lt_re",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB2.fractTail_one_eq_of_one_lt_re",
      "statement": "theorem fractTail_one_eq_of_one_lt_re {s : ℂ} (hs : 1 < s.re) : fractTail s 1 = 1 / (s - 1) - riemannZeta s / s",
