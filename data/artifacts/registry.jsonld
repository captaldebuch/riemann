    {
      "@id": "theorem:NBMellinTools.NB2.bdApprox_eq_tail_of_one_lt",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB2.bdApprox_eq_tail_of_one_lt",
      "statement": "theorem bdApprox_eq_tail_of_one_lt (N : ℕ) (coeffs : Fin N → ℝ) {x : ℝ} (hx : 1 < x) : bdApprox N coeffs x = (∑ k, coeffs k / (k.val + 1 : ℝ)) / x",
      "source": {
        "file": "proofs/NBMellinTools/BaezDuarteTail.lean",
        "line": 63,
        "module": "NBMellinTools.BaezDuarteTail",
        "commit": "16f0b2f465c5410a788279615f668d6a88e0ae80"
      },
      "verification": {
        "status": "proved",
        "newAxioms": 0,
        "sorries": 0
      },
      "tags": [
        "lean",
        "nbmellintools"
      ],
      "summary": "- A finite approximant has a single scalar reciprocal tail."
    },
    {
      "@id": "theorem:NBMellinTools.NB2.chi01_eq_indicator",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB2.chi01_eq_indicator",
      "statement": "theorem chi01_eq_indicator (x : ℝ) : ((chi01 x : ℝ) : ℂ) = (Ioc (0 : ℝ) 1).indicator (fun _ ↦ (1 : ℂ)) x",
      "source": {
        "file": "proofs/NBMellinTools/NB2Mellin.lean",
        "line": 45,
        "module": "NBMellinTools.NB2Mellin",
        "commit": "16f0b2f465c5410a788279615f668d6a88e0ae80"
      },
      "verification": {
        "status": "proved",
        "newAxioms": 0,
        "sorries": 0
      },
      "tags": [
        "lean",
        "nbmellintools"
      ],
      "summary": "- `chi01`, coerced to `ℂ`, is the indicator of `(0, 1]`."
    },
    {
      "@id": "theorem:NBMellinTools.NB2.chi_sub_bdApprox_eq_tail_of_one_lt",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB2.chi_sub_bdApprox_eq_tail_of_one_lt",
      "statement": "theorem chi_sub_bdApprox_eq_tail_of_one_lt (N : ℕ) (coeffs : Fin N → ℝ) {x : ℝ} (hx : 1 < x) : chi01 x - bdApprox N coeffs x = -(∑ k, coeffs k / (k.val + 1 : ℝ)) / x",
      "source": {
        "file": "proofs/NBMellinTools/BaezDuarteTail.lean",
        "line": 75,
        "module": "NBMellinTools.BaezDuarteTail",
        "commit": "16f0b2f465c5410a788279615f668d6a88e0ae80"
      },
      "verification": {
        "status": "proved",
        "newAxioms": 0,
        "sorries": 0
      },
      "tags": [
        "lean",
        "nbmellintools"
      ],
      "summary": "- The complete approximation error therefore has an exact reciprocal tail on `(1,∞)`."
    },
