      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB3.mellin_split_at_one",
      "statement": "private theorem mellin_split_at_one {s : ℂ} (hs0 : 0 < s.re) (hs1 : s.re < 1) (N : ℕ) (coeffs : Fin N → ℝ) : mellin (fun x : ℝ ↦ ((chi01 x - bdApprox N coeffs x : ℝ) : ℂ)) s = (∫ x in Ioc (0 : ℝ) 1, mellinKernel s x * mellinError N coeffs x) + (∫ x in Ioi (1 : ℝ), mellinKernel s x * mellinError N coeffs x)",
