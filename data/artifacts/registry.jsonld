    {
      "@id": "theorem:NBMellinTools.NB2.mellin_rhoBD",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB2.mellin_rhoBD",
      "statement": "theorem mellin_rhoBD (k : ℕ) {s : ℂ} (h0 : 0 < s.re) (h1 : s.re < 1) : mellin (fun x : ℝ ↦ (rhoBD k x : ℂ)) s = -(riemannZeta s) / (s * ((((k + 1 : ℕ) : ℝ) : ℂ) ^ s))",
