      "@id": "theorem:NBMellinTools.NB2.integral_Ioc_fract_cpow",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB2.integral_Ioc_fract_cpow",
      "statement": "theorem integral_Ioc_fract_cpow {s : ℂ} (h1 : s.re < 1) : (∫ t : ℝ in Ioc (0 : ℝ) 1, (t : ℂ) ^ (-s - 1) * ((Int.fract t : ℝ) : ℂ)) = 1 / (1 - s)",
