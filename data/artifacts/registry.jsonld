    {
      "@id": "theorem:NBMellinTools.NB4.vanishing_transport_of_field_1",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB4.vanishing_transport_of_field_1",
      "statement": "theorem vanishing_transport_of_field_1 (hfield1 : ∀ s₀ : ℂ, 1 / 2 < s₀.re → s₀.re < 1 → ∃ C : ℝ, 0 ≤ C ∧ ∀ (N : ℕ) (coeffs : Fin N → ℝ), ‖mellin (fun x : ℝ => ((chi01 x - bdApprox N coeffs x : ℝ) : ℂ)) s₀‖ ≤ C * Real.sqrt (BaezDuarteL2Error N coeffs)) (s₀ : ℂ) (hs0 : 1 / 2 < s₀.re) (hs1 : s₀.re < 1) (hcriterion : NymanBeurlingCriterion) (hgens : ∀ k : ℕ, mellin (fun x : ℝ => (rhoBD k x : ℂ)) s₀ = 0) : mellin (fun x : ℝ => (chi01 x : ℂ)) s₀ = 0",
      "source": {
        "file": "proofs/NBMellinTools/NB4ZeroDetection.lean",
        "line": 243,
        "module": "NBMellinTools.NB4ZeroDetection",
        "commit": "16f0b2f465c5410a788279615f668d6a88e0ae80"
      },
      "verification": {
        "status": "proved",
        "newAxioms": 0,
        "sorries": 0
      },
      "tags": [
        "lean",
        "nbmellintools"
      ],
      "summary": "- An abstract Field 1 estimate transports generator vanishing to the vanishing of the target transform."
    },
    {
