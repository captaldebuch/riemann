    {
      "@id": "theorem:NBMellinTools.NB2.fractTail_one_eq_on_strip",
      "@type": "FormalTheorem",
      "name": "NBMellinTools.NB2.fractTail_one_eq_on_strip",
      "statement": "theorem fractTail_one_eq_on_strip {s : ℂ} (h0 : 0 < s.re) (h1 : s.re < 1) : fractTail s 1 = (1 + 1 / (s - 1) - riemannZeta s) / s",
