# RML Mapping Rules: Corpus JSON → RDF (BIBO, FOAF, DCTERMS, CITO, SKOS)
# Phase 2: Ontology Mapping
# Source: rh_corpus_database_cleaned.json
# Output: RDF Turtle files (articles.ttl, authors.ttl, concepts.ttl, etc.)

@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dcmitype: <http://purl.org/dc/dcmitype/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix schema: <https://schema.org/> .
@prefix cito: <http://purl.org/spar/cito/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rh: <http://data.rh-corpus.org/> .

# ============================================================================
# MAPPING 1: Articles (Main Entity)
# ============================================================================

<#ArticleMapping>
    a rr:TriplesMap ;

    rml:logicalSource [
        rml:source "rh_corpus_database_cleaned.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$.articles[*]"
    ] ;

    # Subject: http://data.rh-corpus.org/article/{arxiv_id_or_id}
    rr:subjectMap [
        rr:template "http://data.rh-corpus.org/article/{id}" ;
        rr:class bibo:AcademicArticle
    ] ;

    # dcterms:title
    rr:predicateObjectMap [
        rr:predicate dcterms:title ;
        rr:objectMap [
            rml:reference "title" ;
            rr:language "en"
        ]
    ] ;

    # dcterms:issued (Year)
    rr:predicateObjectMap [
        rr:predicate dcterms:issued ;
        rr:objectMap [
            rml:reference "year" ;
            rr:datatype xsd:gYear
        ]
    ] ;

    # dcterms:creator (Authors via join)
    rr:predicateObjectMap [
        rr:predicate dcterms:creator ;
        rr:objectMap [
            rr:parentTriplesMap <#AuthorMapping> ;
            rr:joinCondition [
                rr:child "id" ;
                rr:parent "article_id"
            ]
        ]
    ] ;

    # bibo:arxivId
    rr:predicateObjectMap [
        rr:predicate bibo:arxivId ;
        rr:objectMap [
            rml:reference "arxiv_id" ;
            rr:datatype xsd:string
        ]
    ] ;

    # bibo:doi (if present)
    rr:predicateObjectMap [
        rr:predicate bibo:doi ;
        rr:objectMap [
            rml:reference "doi" ;
            rr:datatype xsd:string
        ]
    ] ;

    # schema:downloadUrl (PDF location)
    rr:predicateObjectMap [
        rr:predicate schema:downloadUrl ;
        rr:objectMap [
            rr:template "file:///{local_pdf_path}"
        ]
    ] ;

    # rh:projectRole (custom property)
    rr:predicateObjectMap [
        rr:predicate <http://data.rh-corpus.org/projectRole> ;
        rr:objectMap [
            rml:reference "role_in_project" ;
            rr:datatype xsd:string
        ]
    ] ;

    # dcterms:subject (concepts - join to concept list)
    rr:predicateObjectMap [
        rr:predicate dcterms:subject ;
        rr:objectMap [
            rr:template "http://data.rh-corpus.org/concept/{concept_slug}" ;
        ]
    ] ;

    # dcterms:description (relevance note)
    rr:predicateObjectMap [
        rr:predicate dcterms:description ;
        rr:objectMap [
            rr:template "Relevance score: {relevance_score}; Tags: {tags_str}"
        ]
    ] .


# ============================================================================
# MAPPING 2: Authors
# ============================================================================

<#AuthorMapping>
    a rr:TriplesMap ;

    rml:logicalSource [
        rml:source "rh_corpus_database_cleaned.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$.articles[*].authors[*]"
    ] ;

    # Subject: http://data.rh-corpus.org/author/{author_slug}
    rr:subjectMap [
        rr:template "http://data.rh-corpus.org/author/{name_slug}" ;
        rr:class foaf:Person
    ] ;

    # foaf:name
    rr:predicateObjectMap [
        rr:predicate foaf:name ;
        rr:objectMap [
            rml:reference "name"
        ]
    ] ;

    # foaf:workplaceHomepage (if affiliation provided)
    rr:predicateObjectMap [
        rr:predicate foaf:workplaceHomepage ;
        rr:objectMap [
            rml:reference "affiliation"
        ]
    ] .


# ============================================================================
# MAPPING 3: Concepts (Tags/Keywords → SKOS)
# ============================================================================

<#ConceptMapping>
    a rr:TriplesMap ;

    rml:logicalSource [
        rml:source "rh_corpus_database_cleaned.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$.articles[*].tags[*]"
    ] ;

    # Subject: http://data.rh-corpus.org/concept/{tag}
    rr:subjectMap [
        rr:template "http://data.rh-corpus.org/concept/{tag_slug}" ;
        rr:class skos:Concept
    ] ;

    # skos:prefLabel
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [
            rml:reference "tag" ;
            rr:language "en"
        ]
    ] .


# ============================================================================
# MAPPING 4: Mathematical Theorems (if present in insights)
# ============================================================================

<#TheoremMapping>
    a rr:TriplesMap ;

    rml:logicalSource [
        rml:source "rh_corpus_database_cleaned.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$.articles[*].insights.main_theorem"
    ] ;

    # Subject: http://data.rh-corpus.org/theorem/{article_id}
    rr:subjectMap [
        rr:template "http://data.rh-corpus.org/theorem/{id}_main" ;
        rr:class <http://data.rh-corpus.org/Theorem>
    ] ;

    # rdfs:label
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [
            rml:reference "main_theorem"
        ]
    ] ;

    # rh:inArticle (link back to article)
    rr:predicateObjectMap [
        rr:predicate <http://data.rh-corpus.org/inArticle> ;
        rr:objectMap [
            rr:template "http://data.rh-corpus.org/article/{id}"
        ]
    ] .


# ============================================================================
# NOTES & USAGE
# ============================================================================

# To execute these mappings with an RML processor (e.g., RMLMapper):
#
# 1. Install RMLMapper:
#    wget https://github.com/RMLio/rmlmapper-java/releases/download/v6.1.3/rmlmapper.jar
#
# 2. Create execution config (config.xml):
#    <rmlmapper>
#        <source>
#            <input>rh_corpus_database_cleaned.json</input>
#            <referenceFormulation>JSONPATH</referenceFormulation>
#        </source>
#        <output>
#            <format>TURTLE</format>
#            <file>output.ttl</file>
#        </output>
#    </rmlmapper>
#
# 3. Run mapper:
#    java -jar rmlmapper.jar -m lod_phase2_mappings.ttl -o articles.ttl
#
# Alternative: Use Python RML processor (rdflib + custom script)
# See lod_phase2_generate_rdf.py

# ============================================================================
# MANUAL ADDITIONS (to be added post-RML generation)
# ============================================================================

# 1. External entity linking via owl:sameAs
#    Example: Authors linked to Wikidata/ORCID
#    :author_hadamard owl:sameAs <https://www.wikidata.org/wiki/Q164425> .

# 2. Citation relationships via CiTO
#    Example: Paper A cites Paper B
#    rh:article_2607.09797 cito:citesAsAuthority rh:article_1601.06839 .

# 3. Concept relationships via SKOS
#    Example: Narrower concepts
#    rh:concept_zeta_function skos:narrower rh:concept_dirichlet_character .

# 4. Formalization status (custom RH namespace)
#    Example: Formal readiness tracking
#    rh:article_vasyunin form:formalizable true ;
#             form:readiness "complete" ;
#             form:leanProofPath "mathlib/NBMellinTools/NB2BaseMellin.lean" .
