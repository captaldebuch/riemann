{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riemann-hypothesis.github.io/artifacts/schema/artifact.schema.json",
  "title": "RH Formalization Artifact",
  "description": "A source, formalization, or research artifact in the RH formalization knowledge graph.",
  "type": "object",
  "required": ["@id", "@type", "name"],
  "properties": {
    "@id": {
      "type": "string",
      "pattern": "^\\S+$",
      "description": "Stable, namespaced identifier such as paper:1211.5191 or theorem:NB5.foo."
    },
    "@type": {
      "type": "string",
      "enum": [
        "SourcePaper",
        "Mathematician",
        "Concept",
        "FormalTheorem",
        "FormalLemma",
        "FormalDefinition",
        "FormalAxiom",
        "FormalStructure",
        "FormalModule",
        "ResearchGate",
        "Roadmap",
        "Decision",
        "Diagnostic",
        "Experiment"
      ]
    },
    "name": {"type": "string", "minLength": 1},
    "statement": {"type": "string"},
    "summary": {"type": "string"},
    "source": {
      "type": "object",
      "properties": {
        "file": {"type": "string"},
        "line": {"type": "integer", "minimum": 1},
        "commit": {"type": "string"},
        "module": {"type": "string"}
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["proved", "contains_sorry", "assumed", "declaration", "unknown"]
        },
        "newAxioms": {"type": "integer", "minimum": 0},
        "sorries": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "paperClaims": {
      "type": "array",
      "description": "Reviewed claims imported, translated, or applied from a source paper. This records applicability, not merely bibliographic relevance.",
      "items": {
        "type": "object",
        "required": ["sourcePaper", "claim", "validity"],
        "properties": {
          "sourcePaper": {
            "type": "string",
            "pattern": "^paper:",
            "description": "The SourcePaper artifact from which this claim is taken."
          },
          "claim": {
            "type": "string",
            "minLength": 1,
            "description": "The precise informal claim or proposed translation being relied upon."
          },
          "sourceLocation": {
            "type": "object",
            "properties": {
              "theorem": {"type": "string"},
              "section": {"type": "string"},
              "page": {"type": "integer", "minimum": 1},
              "equation": {"type": "string"}
            },
            "additionalProperties": false
          },
          "validity": {
            "type": "object",
            "required": ["status", "method", "reviewedAt", "note"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["sound", "conditional", "scope_mismatch", "unsupported", "contradicted", "unreviewed"]
              },
              "method": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "enum": ["source-reading", "hypothesis-check", "definition-check", "formalization-check", "numerical-check", "counterexample", "external-erratum"]
                },
                "uniqueItems": true
              },
              "reviewedAt": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "reviewedBy": {"type": "string", "minLength": 1},
              "conditions": {
                "type": "array",
                "items": {"type": "string", "minLength": 1},
                "uniqueItems": true
              },
              "note": {
                "type": "string",
                "minLength": 1,
                "description": "A concise explanation of the review outcome; mandatory so a non-sound result cannot be silently used."
              }
            },
            "additionalProperties": false,
            "allOf": [
              {
                "if": {"properties": {"status": {"const": "conditional"}}},
                "then": {"required": ["conditions"]}
              }
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "difficulty": {"type": "string"},
    "openProblem": {"type": "boolean"}
  },
  "additionalProperties": true
}
