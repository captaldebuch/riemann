        function setRedirect()
        {
            event.preventDefault();
            if ("https://pubs.ams.org/view?ProductCode=bull&amp;directory=1985-12-02&amp;pii=s0273-0979-1985-15349-2" == "") 
            {
                // we are on the browse page, need to set propery with javascript()
                var returnUrl = getShareUrl();
                returnUrl = encodeURIComponent(returnUrl);
                var baseUrl = $(this).prop("href");
                var questionOrAnd = baseUrl.includes("?") ? "&" : "?";
                location.href = baseUrl + questionOrAnd + "returnUrl=" + returnUrl;
            }
            else
            {
                location.href = $(this).prop("href");
            }
        }

        
    

    </script>
