lemma vasyunin_log_div (h k : ℕ) (h_pos : 0 < h) (k_pos : 0 < k) :
  Real.log ((h : ℝ) / (k : ℝ)) = Real.log (h : ℝ) - Real.log (k : ℝ) := by
  exact Real.log_div (by exact_mod_cast ne_of_gt h_pos) (by exact_mod_cast ne_of_gt k_pos)

